rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - storeName: string (required, max 100 chars)
    //   - whatsappNumber: string (optional, max 20 chars)
    //   - logoUrl: string (optional, max 500 chars, valid URL)
    //   - defaultMargin: number (optional, >= 0)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - uid: string (required, must match owner)
    //   - name: string (required, max 200 chars)
    //   - originalPrice: number (required, >= 0)
    //   - baseCurrency: string (required, max 10 chars)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }
    function isValidOptionalUrl(field) {
      return !(field in request.resource.data) || isValidUrl(request.resource.data[field]);
    }
    function isValidOptionalNumber(field, minVal) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is number && request.resource.data[field] >= minVal);
    }

    // Domain Validators
    function isValidUser(data) {
      return hasOnlyAllowedFields(['storeName', 'whatsappNumber', 'logoUrl', 'defaultMargin']) &&
             validStringLength('storeName', 1, 100) &&
             isValidOptionalString('whatsappNumber', 0, 20) &&
             isValidOptionalUrl('logoUrl') &&
             isValidOptionalNumber('defaultMargin', 0);
    }

    function isValidProduct(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'originalPrice', 'baseCurrency', 'createdAt']) &&
             validStringLength('name', 1, 200) &&
             request.resource.data.originalPrice is number && request.resource.data.originalPrice >= 0 &&
             validStringLength('baseCurrency', 1, 10) &&
             request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /products/{productId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidProduct(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && isValidProduct(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
